void setup(){
  size(500, 500); 
  background(#82EFFC); 
  }
void draw(){
  fill(#EEFF0F); 
  strokeWeight(2); 
   circle(250, 330, 300);
   fill(#FF0000); 
   ellipse(190, 295, 50, 80); 
   fill(#FF0000);
   ellipse(300, 295, 50, 80);
   fill(255);  
   rect(175, 380, 150, 50); 
   line(175, 405, 325, 405); 
   fill(#1BFF08);
   triangle(255, 125, 105, 245, 395, 245);
   fill(#FFD562);
   rect(230, 335, 30, 30);
}
